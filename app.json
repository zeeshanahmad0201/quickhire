{
  "expo": {
    "name": "Quickhire",
    "slug": "quickhire",
    "scheme": "quickhire",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.xeeshan-ahmad.quickhire",
      "appleTeamId": "RLSJQFUA32",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "QuickHire needs your location to show nearby services."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.xeeshanahmad.quickhire",
      "permissions": [
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "QuickHire needs your location to show nearby services."
        }
      ]
    ]
  }
}